# ============================================================================
# B2B Trade & Logistics Platform — Environment Variables
# ============================================================================
# Copy to `.env.local` for local dev. On Vercel, set these under
# Project → Settings → Environment Variables for Production, Preview, and
# Development. NEXT_PUBLIC_* values are inlined into the client bundle.
# ----------------------------------------------------------------------------

# Supabase project URL (Project Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key — safe in the browser ONLY because RLS is enabled
# on every table (Project Settings → API → anon public).
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key — SERVER ONLY. Bypasses RLS. Used by Edge Functions
# and admin server tasks. NEVER prefix with NEXT_PUBLIC_ and never expose to the
# client. (Project Settings → API → service_role).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Canonical site URL — used for auth redirect/callback URLs.
# Local: http://localhost:3000 — Vercel: your production domain.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional CDN/asset prefix. Leave empty for normal Vercel root-domain serving.
NEXT_PUBLIC_ASSET_PREFIX=
